script = ExtResource("1")
id = "fired_exec"
display_name = "The Fired Corporate Exec"
title = "The Golden Parachute That Didn't Open"
blurb = "You had the corner office until the merger. Security walked you out with a box.

+ Business & Charisma start high. Old Rolodex: three wealthy contacts still take your calls. One VERY nice suit.
- Champagne Taste: cheap food, cheap beds, and bus rides drain your Mood twice as fast. Industry Blacklist: your old rival is out there, badmouthing you. Car payments due on a car you can't afford.

Comfortable start. Expensive soul."
difficulty = 2
