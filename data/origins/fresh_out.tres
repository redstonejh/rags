script = ExtResource("1")
id = "fresh_out"
display_name = "The Ex-Con"
title = "Fresh Out"
blurb = "Eight years inside. The world got smartphones; you got a bus ticket and gate money.

+ Prison-yard physique: Fighting starts high, pain is a rumor. Yard Respect: the street trusts you on sight.
- The Record: background checks bounce you from good jobs until you stay clean long enough to seal it. Everyone you knew is a felony waiting to reconnect.

Going Straight is a real path. Most don't make it."
opening_line = "The Ex-Con arrives at the bus stop with gate money in one pocket and parole breathing down the other."
