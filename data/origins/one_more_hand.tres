script = ExtResource("1")
id = "one_more_hand"
display_name = "The Gambler"
title = "One More Hand"
blurb = "You were up $40K at 2 AM. You remember that part very clearly.

+ Luck is REAL for you alone: every roll in your life quietly rolls twice and keeps the better one. Card skill pays.
- $150 a week to Big Mickey says you owe him $15,000, and Mickey employs two large opinions about late payments.

The casino gave you a chip for the bus. You kept it."
opening_line = "The Gambler rolls into the bus stop with one lucky chip and Big Mickey's payment clock already running."
