[resource]
script = ExtResource("1")
id = "struck_off"
display_name = "The Disgraced Doctor"
title = "Struck Off"
blurb = "Twelve years of training. One pill scandal. The license is gone; the hands still remember.

+ Medicine maxed: treat your own wounds free, forever. People trust a doctor's voice even now.
- Wage garnishment takes 25% of every legal paycheck (the student loans survived the scandal). A quiet oxy problem that is not, currently, quiet.

You sleep in a nice car. It's the last thing they couldn't take."
