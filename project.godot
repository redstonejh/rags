; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.

config_version=5

[application]

config/name="RAGS"
config/description="A dark-comedy life sim about starting from nothing. Everyone starts in rags; riches optional."
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
GameClock="*res://scripts/autoload/game_clock.gd"
ContentDB="*res://scripts/autoload/content_db.gd"
WorldState="*res://scripts/autoload/world_state.gd"
SimEngine="*res://scripts/autoload/sim_engine.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
GameFlow="*res://scripts/autoload/game_flow.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

